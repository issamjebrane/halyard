# Copy to mt5/.env and fill in. Runs on a Windows VPS alongside the MT5 terminal.
# NEVER commit the filled-in .env (the service-role key + MT5 password are secrets).

# --- Supabase (signal source of truth) ---
SUPABASE_URL=https://gswxrgoeiqszaawzltwm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- MetaTrader 5 account (use a DEMO account first) ---
# If the terminal is already running and logged in, you can leave these blank
# and the bot connects to the open terminal. Otherwise it logs in for you.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=        # optional, e.g. C:\Program Files\MetaTrader 5\terminal64.exe

# --- Which signals to copy ---
SIGNAL_SOURCE=telegram:gold_vip
SYMBOL=XAUUSD             # your broker's gold symbol (e.g. XAUUSD, GOLD, XAUUSD.m)

# --- Risk / sizing ---
RISK_PCT=0.5             # % of balance risked if SL is hit (per signal, across all splits)
SPLIT=3                  # split volume across this many TPs (1-3); BE after TP1
MAX_OPEN_TRADES=6        # refuse new signals beyond this many open positions
MAX_SPREAD_POINTS=60     # skip if current spread (points) exceeds this
MAX_ENTRY_SLIPPAGE=2.0   # skip if |current price - signal entry| exceeds this (price units)
MAX_SIGNAL_AGE_MIN=15    # never act on a signal older than this (avoids back-trading history)
DEVIATION=20             # max price deviation (points) for market fills
MAGIC=778899             # EA magic number stamped on the bot's orders

# --- Safety ---
DRY_RUN=true             # true = log intended trades, place NOTHING. Flip to false to trade the demo.
POLL_SECONDS=5
