# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Price feed: Binance PAX Gold (PAXGUSDT). Public host, no key needed. ---
BINANCE_PRICE_URL=https://data-api.binance.vision/api/v3/ticker/price?symbol=PAXGUSDT

# --- Binance account keys (server-side only; restrict key, no withdrawals). ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Telegram (read-only ingester) ---
# api_id/api_hash from my.telegram.org. TELEGRAM_SESSION from `npm run tg:login`.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL=Gold VIP signal

# --- Gemini (Flash) signal parser — OPTIONAL smart fallback to the regex parser ---
# Key from aistudio.google.com (free tier available). Cost-capped: regex parses the
# canonical format for free; only messy/other-format messages hit Gemini, behind a cap.
GEMINI_API_KEY=
LLM_PARSE=on                    # off => pure regex (no API calls at all)
GEMINI_MODEL=gemini-2.0-flash
LLM_PARSE_DAILY_MAX=200         # hard ceiling on LLM calls per UTC day

# --- MetaApi executor (no-Windows path; runs on Linux) ---
# Token + account id from app.metaapi.cloud after linking your MT5 demo account.
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
METAAPI_REGION=

# --- Executor tuning (used by scripts/metaapi-executor.mjs) ---
SIGNAL_SOURCE=telegram:gold_vip
SYMBOL=XAUUSD
RISK_PCT=0.5
SPLIT=3
MAX_OPEN_TRADES=6
MAX_ENTRY_SLIPPAGE=2.0
MAX_SIGNAL_AGE_MIN=15
DRY_RUN=true
POLL_SECONDS=5
